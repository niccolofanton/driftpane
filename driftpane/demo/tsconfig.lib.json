{
	"//": "Build del layer (driftpane/src) in demo/lib come ES module per la demo.",
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"strict": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"sourceMap": true,
		"rootDir": "../src",
		"outDir": "./lib"
	},
	"include": ["../src/**/*.ts"]
}
