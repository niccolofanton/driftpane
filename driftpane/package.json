{
	"name": "driftpane",
	"version": "1.0.0",
	"description": "Non-invasive layer on top of Tweakpane v4: localStorage state persistence, a draggable/resizable panel, persistent fold state, and a presets menu (save/apply/export/import JSON).",
	"type": "module",
	"sideEffects": [
		"**/*.css"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./theme.css": "./theme.css",
		"./package.json": "./package.json"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"theme.css",
		"README.md",
		"LICENSE.txt",
		"CHANGELOG.md"
	],
	"scripts": {
		"clean": "rimraf dist",
		"build": "npm run clean && tsc -p tsconfig.build.json",
		"typecheck": "tsc -p tsconfig.json",
		"lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
		"format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"prepack": "npm run build",
		"prepare": "npm run build",
		"prepublishOnly": "npm run build && npm run test"
	},
	"keywords": [
		"tweakpane",
		"gui",
		"controls",
		"persistence",
		"localstorage",
		"presets",
		"draggable",
		"panel",
		"settings",
		"debug-ui"
	],
	"author": "niccolofanton",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/niccolofanton/driftpane.git",
		"directory": "driftpane"
	},
	"homepage": "https://github.com/niccolofanton/driftpane/tree/main/driftpane#readme",
	"bugs": {
		"url": "https://github.com/niccolofanton/driftpane/issues"
	},
	"engines": {
		"node": ">=18"
	},
	"peerDependencies": {
		"tweakpane": "^4.0.0"
	},
	"devDependencies": {
		"@typescript-eslint/eslint-plugin": "^5.62.0",
		"@typescript-eslint/parser": "^5.62.0",
		"@vitest/coverage-v8": "^1.6.1",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.2.1",
		"eslint-plugin-simple-import-sort": "^10.0.0",
		"jsdom": "^24.1.3",
		"prettier": "^3.3.3",
		"rimraf": "^5.0.10",
		"tweakpane": "^4.0.5",
		"typescript": "~5.8.3",
		"vitest": "^1.6.1"
	}
}
